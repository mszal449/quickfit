# --- ServiceConfig ---
DEBUG=true
IS_PRODUCTION=false
PORT=8000
BASE_URL=http://localhost:8000
HOST=127.0.0.1

# --- DatabaseConfig ---
DB_URL=postgresql+asyncpg://user:password@localhost:5432/training
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- AuthConfig --- (JWT_SECRET required, no default — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# --- GoogleOAuthConfig --- (required, no defaults)
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret
